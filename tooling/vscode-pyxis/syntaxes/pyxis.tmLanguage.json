{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "Pyxis",
  "scopeName": "source.pyxis",
  "patterns": [
    { "include": "#doc_comment_inner" },
    { "include": "#doc_comment_outer" },
    { "include": "#line_comment" },
    { "include": "#block_comment" },
    { "include": "#attribute" },
    { "include": "#inner_attribute" },
    { "include": "#keywords" },
    { "include": "#types" },
    { "include": "#strings" },
    { "include": "#raw_strings" },
    { "include": "#numbers" },
    { "include": "#identifiers" },
    { "include": "#punctuation" }
  ],
  "repository": {
    "doc_comment_outer": {
      "match": "^\\s*///.*$",
      "name": "comment.line.documentation.pyxis"
    },
    "doc_comment_inner": {
      "match": "^\\s*//!.*$",
      "name": "comment.line.documentation.pyxis"
    },
    "line_comment": {
      "match": "//[^/!].*$|//$",
      "name": "comment.line.double-slash.pyxis"
    },
    "block_comment": {
      "begin": "/\\*",
      "end": "\\*/",
      "name": "comment.block.pyxis",
      "patterns": [
        { "include": "#block_comment" }
      ]
    },
    "attribute": {
      "name": "meta.attribute.pyxis",
      "begin": "#(?!\\!)\\[",
      "end": "\\]",
      "patterns": [
        { "include": "#strings" },
        { "include": "#numbers" },
        { "include": "#attribute_comment" },
        { "include": "#attribute_content" }
      ]
    },
    "inner_attribute": {
      "name": "meta.attribute.inner.pyxis",
      "begin": "#!\\[",
      "end": "\\]",
      "patterns": [
        { "include": "#strings" },
        { "include": "#numbers" },
        { "include": "#attribute_content" }
      ]
    },
    "attribute_comment": {
      "match": "/\\*.*?\\*/",
      "name": "comment.block.attribute.pyxis"
    },
    "attribute_content": {
      "patterns": [
        {
          "match": "\\b([a-zA-Z_][a-zA-Z0-9_]*)\\s*(?=\\()",
          "captures": { "1": { "name": "entity.name.function.attribute.pyxis" } }
        },
        {
          "match": "\\b([a-zA-Z_][a-zA-Z0-9_]*)\\b",
          "name": "variable.other.attribute.pyxis"
        }
      ]
    },
    "keywords": {
      "patterns": [
        {
          "match": "\\b(pub)\\b",
          "name": "storage.modifier.pyxis"
        },
        {
          "match": "\\b(type|enum|bitflags|impl|extern|use|backend)\\b",
          "name": "keyword.other.pyxis"
        },
        {
          "match": "\\b(fn|vftable|prologue|epilogue)\\b",
          "name": "keyword.other.pyxis"
        },
        {
          "match": "\\b(mut|const|as)\\b",
          "name": "keyword.other.pyxis"
        },
        {
          "match": "\\b(self)\\b",
          "name": "variable.language.pyxis"
        },
        {
          "match": "\\b(Self)\\b",
          "name": "entity.name.type.pyxis"
        }
      ]
    },
    "types": {
      "patterns": [
        {
          "match": "\\b(u8|u16|u32|u64|u128|usize|i8|i16|i32|i64|i128|isize|f32|f64|bool|void|char|c_char|c_int|AtomicBool|AtomicU8|AtomicU16|AtomicU32|AtomicU64|AtomicI8|AtomicI16|AtomicI32|AtomicI64|AtomicPtr)\\b",
          "name": "support.type.primitive.pyxis"
        }
      ]
    },
    "strings": {
      "name": "string.quoted.double.pyxis",
      "begin": "\"",
      "end": "\"",
      "patterns": [
        {
          "match": "\\\\.",
          "name": "constant.character.escape.pyxis"
        }
      ]
    },
    "raw_strings": {
      "name": "string.quoted.raw.pyxis",
      "begin": "r#\"",
      "end": "\"#"
    },
    "numbers": {
      "patterns": [
        {
          "match": "\\b0x[0-9a-fA-F_]+\\b",
          "name": "constant.numeric.hex.pyxis"
        },
        {
          "match": "\\b0b[01_]+\\b",
          "name": "constant.numeric.binary.pyxis"
        },
        {
          "match": "\\b0o[0-7_]+\\b",
          "name": "constant.numeric.octal.pyxis"
        },
        {
          "match": "\\b[0-9][0-9_]*\\b",
          "name": "constant.numeric.decimal.pyxis"
        }
      ]
    },
    "identifiers": {
      "patterns": [
        {
          "match": "\\b([A-Z][a-zA-Z0-9_]*)\\b",
          "name": "entity.name.type.pyxis"
        },
        {
          "match": "\\b([a-z_][a-zA-Z0-9_]*)\\b",
          "name": "variable.other.pyxis"
        }
      ]
    },
    "punctuation": {
      "patterns": [
        {
          "match": "::",
          "name": "punctuation.accessor.pyxis"
        },
        {
          "match": "->",
          "name": "keyword.operator.arrow.pyxis"
        },
        {
          "match": "[{}\\[\\]()<>]",
          "name": "punctuation.definition.pyxis"
        },
        {
          "match": "[;:,]",
          "name": "punctuation.separator.pyxis"
        },
        {
          "match": "[*=&]",
          "name": "keyword.operator.pyxis"
        }
      ]
    }
  }
}
