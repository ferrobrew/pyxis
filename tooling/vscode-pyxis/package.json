{
  "name": "pyxis",
  "displayName": "Pyxis",
  "description": "Language support for the Pyxis DSL: syntax highlighting and language server.",
  "version": "0.1.0",
  "publisher": "ferrobrew",
  "license": "MIT",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Programming Languages"
  ],
  "main": "./dist/extension.js",
  "activationEvents": [
    "onLanguage:pyxis"
  ],
  "contributes": {
    "languages": [
      {
        "id": "pyxis",
        "aliases": [
          "Pyxis"
        ],
        "extensions": [
          ".pyxis"
        ],
        "configuration": "./language-configuration.json"
      }
    ],
    "grammars": [
      {
        "language": "pyxis",
        "scopeName": "source.pyxis",
        "path": "./syntaxes/pyxis.tmLanguage.json"
      }
    ],
    "configuration": {
      "title": "Pyxis",
      "properties": {
        "pyxis.languageServerPath": {
          "type": "string",
          "default": "pyxis-lsp",
          "description": "Path to the pyxis-lsp binary. Defaults to searching PATH."
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "node esbuild.js --production",
    "build": "node esbuild.js",
    "watch": "node esbuild.js --watch"
  },
  "devDependencies": {
    "@types/vscode": "^1.85.0",
    "@types/node": "^20.0.0",
    "esbuild": "^0.20.0",
    "typescript": "^5.3.0"
  },
  "dependencies": {
    "vscode-languageclient": "^9.0.1"
  }
}
