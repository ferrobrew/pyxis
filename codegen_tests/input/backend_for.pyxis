// Tests `for <Type>` attribution on backend splices. Splices tagged
// `for <Type>` supply backend code attributed to that type (rendered on
// the type's documentation page) rather than the enclosing module.
#[align(4)]
pub type Widget {
    pub id: u32,
}
impl Widget {
    #[external_body]
    pub fn make() -> Widget;
    #[external_body]
    pub fn get_id(&self) -> u32;
}

// Tagged epilogue (shorthand form): lands on Widget's type page.
backend rust epilogue for Widget r#"
    impl Widget {
        pub fn make() -> Widget { Widget { id: 0 } }
        pub fn get_id(&self) -> u32 { self.id }
    }
"#;

backend cpp epilogue for Widget r#"
inline Widget Widget::make() { return Widget{0}; }
inline ::std::uint32_t Widget::get_id() const { return id; }
"#;

// Untagged module-level epilogue: stays on the module page.

#[external_body]
pub fn module_init() -> u32;

backend rust epilogue r#"
    pub fn module_init() -> u32 { 1 }
"#;

backend cpp epilogue r#"
inline ::std::uint32_t module_init() { return 1; }
"#;

// Tagged prologue + epilogue via braced form, on a different type.
#[size(0x8)]
pub type Handle {
    pub raw: *mut u8,
}
impl Handle {
    #[external_body]
    pub fn null() -> Handle;
}

backend rust {
    prologue for Handle r#"
type HandleRaw = *mut u8;
"#;
    epilogue for Handle r#"
    impl Handle {
        pub fn null() -> Handle { Handle { raw: std::ptr::null_mut() } }
    }
"#;
}

backend cpp {
    prologue for Handle r#"
using HandleRaw = ::std::uint8_t*;
"#;
    epilogue for Handle r#"
inline Handle Handle::null() { return Handle{nullptr}; }
"#;
}
