// A top-level module referencing types from a folder module, to exercise
// `crate::world::...` path resolution from outside the folder: both a leaf
// module type (`world::weather::Weather`) and a type defined directly in
// the folder module (`world::World`).
use world::weather::Weather;
use world::World;

/// Consumes the world. Doc-links a type from a deeper, un-imported module
/// ([`DeepMarker`](world::deep::marker::DeepMarker)) to exercise cross-module
/// doc-link resolution: the link destination must be rewritten to an absolute
/// crate path so rustdoc resolves it without a `use` import.
#[size(0x10)]
pub type WorldConsumer {
    pub weather: *mut Weather,
    pub world: *mut World,
}
